# Auth (generate with: openssl rand -base64 32)
API_SECRET_KEY=
AUTH_SECRET=
AUTH_TRUST_HOST=true  # required on Railway (behind reverse proxy)

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/eth-silesia-2026-hackathon

# LiteLLM proxy
LITELLM_BASE_URL=
LITELLM_API_KEY=

# LangSmith (optional)
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT="eth-silesia-local"

# Railway — required for Next.js standalone to bind correctly
HOSTNAME=0.0.0.0

# SMS
BULKGATE_API_KEY=
BULKGATE_APP_ID=
