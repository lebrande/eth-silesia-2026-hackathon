# Required.
ELEVENLABS_API_KEY=

# Required. A male voice with Polish in its verified_languages.
# Recommended (decided after testing — see thoughts/notes/elevenlabs-silesian-feasibility.md):
#   - Adam - Serious, Rich, and Smoky (Mazovian accent): hIssydxXZ1WuDorjx6Ic
# Other Polish-capable male stock voices on the account:
#   - Liam    (verified_languages includes pl): TX3LPaxmHKxFdv7VOQHJ
#   - Donovan (verified_languages includes pl): DMyrgzQFny3JI1Y1paM5
#   - Marcin  (Polish name, narrative_story):   MXt9WArfiuiT7MmD6D61
#
# Do NOT use the classic "Adam - Dominant, Firm" (pNInz6obpgDQGcFmaJgB) —
# empty verified_languages, English-biased, sounds wrong on Polish/Silesian text.
VOICE_ID_STOCK=hIssydxXZ1WuDorjx6Ic

# Optional. Not needed for the recommended stack. Set this only if you want to
# A/B a cloned voice — see voice-sample/README.md. Leave blank otherwise.
VOICE_ID_CLONE=
